{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Build Runner",
      "type": "shell",
      "command": "flutter pub run build_runner build --delete-conflicting-outputs",
      "group": {
        "kind": "build",
        "isDefault": false
      },
      "problemMatcher": []
    },
    {
      "label": "Flutter Pub Get",
      "type": "shell",
      "command": "flutter pub get",
      "group": {
        "kind": "build",
        "isDefault": false
      },
      "problemMatcher": []
    },
    {
      "label": "Flutter Clean",
      "type": "shell",
      "command": "flutter clean",
      "group": {
        "kind": "build",
        "isDefault": false
      },
      "problemMatcher": []
    },
    {
      "label": "Ship Android",
      "type": "shell",
      "command": "fastlane internal",
      "options": {
        "cwd": "${workspaceFolder}/android"
      },
      "group": {
        "kind": "build",
        "isDefault": false
      }
    },
    {
      "label": "Ship iOS",
      "type": "shell",
      "command": "fastlane beta",
      "options": {
        "cwd": "${workspaceFolder}/ios"
      },
      "group": {
        "kind": "build",
        "isDefault": false
      }
    }
  ]
}
